#!/usr/bin/env python3
from __future__ import annotations

from pathlib import Path


HEADER = """# ==================================================================
# WARNING: This file is auto-generated by generate-compose.
# Do not modify this file directly. Update compose.template.yaml
# and regenerate this file instead.
# ==================================================================

"""


def main() -> None:
    docker_dir = Path(__file__).resolve().parent
    template_path = docker_dir / "compose.template.yaml"
    output_path = docker_dir / "compose.yaml"

    if not template_path.exists():
        raise SystemExit(f"missing template: {template_path}")

    output_path.write_text(HEADER + template_path.read_text(encoding="utf-8"), encoding="utf-8")
    print(f"generated {output_path}")


if __name__ == "__main__":
    main()

